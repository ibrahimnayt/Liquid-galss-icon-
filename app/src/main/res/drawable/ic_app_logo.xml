<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- deep glossy glass body: bright top fading to near-black -->
    <path android:pathData="M9,54 a45,45 0 1,0 90,0 a45,45 0 1,0 -90,0Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="10"
                android:endX="54" android:endY="98"
                android:startColor="#3DFFFFFF"
                android:endColor="#B3101012" />
        </aapt:attr>
    </path>

    <!-- thin light rim around the edge -->
    <path
        android:pathData="M9,54 a45,45 0 1,0 90,0 a45,45 0 1,0 -90,0Z"
        android:strokeColor="#26FFFFFF"
        android:strokeWidth="1.2"
        android:fillColor="#00000000" />

    <!-- soft specular gloss near the top -->
    <path android:pathData="M18,30 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0Z" android:fillColor="#26FFFFFF" />

    <!-- cool glow hugging the bottom edge -->
    <path android:pathData="M26,88 a28,9 0 1,0 56,0 a28,9 0 1,0 -56,0Z" android:fillColor="#4D78AAFF" />

    <!-- glyph -->
    <group android:translateX="30" android:translateY="30" android:scaleX="2" android:scaleY="2">
        <path android:pathData="M32,54 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0Z" android:strokeColor="#CCFFFFFF" android:strokeWidth="2.2" android:fillColor="#00000000" />
    </group>
</vector>
